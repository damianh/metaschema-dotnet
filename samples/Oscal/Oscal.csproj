<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>library</OutputType>
    <Description>OSCAL (Open Security Controls Assessment Language) library with versioned type-safe C# models generated from NIST Metaschema definitions.</Description>
    <ImplicitUsings>true</ImplicitUsings>
    <!-- Disable default compile includes since we explicitly specify versioned folders -->
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <!-- Include all versioned generated files -->
    <Compile Include="V1_2_0\Generated\**\*.g.cs" />
    <!-- Future versions: -->
    <!-- <Compile Include="V1_3_0\Generated\**\*.g.cs" /> -->
  </ItemGroup>

</Project>
