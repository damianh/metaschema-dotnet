<?xml version="1.0" encoding="UTF-8"?>
<METASCHEMA xmlns="http://csrc.nist.gov/ns/oscal/metaschema/1.0">
  <schema-name>Simple Test Module</schema-name>
  <short-name>simple-test</short-name>
  <schema-version>1.0.0</schema-version>
  <namespace>http://example.com/ns/simple-test</namespace>
  <json-base-uri>http://example.com/schema/simple-test</json-base-uri>
  <remarks>
    <p>This is a simple test module for unit testing.</p>
  </remarks>

  <define-flag name="id" as-type="token">
    <formal-name>Identifier</formal-name>
    <description>A unique identifier.</description>
  </define-flag>

  <define-flag name="name" as-type="string">
    <formal-name>Name</formal-name>
    <description>A human-readable name.</description>
  </define-flag>

  <define-field name="title" as-type="string">
    <formal-name>Title</formal-name>
    <description>A title for the document.</description>
  </define-field>

  <define-field name="description" as-type="markup-multiline">
    <formal-name>Description</formal-name>
    <description>A description with markup support.</description>
    <flag ref="id" required="yes"/>
  </define-field>

  <define-assembly name="document">
    <formal-name>Document</formal-name>
    <description>A document assembly.</description>
    <root-name>document</root-name>
    <flag ref="id" required="yes"/>
    <flag ref="name"/>
    <model>
      <field ref="title" min-occurs="1" max-occurs="1"/>
      <field ref="description" min-occurs="0" max-occurs="unbounded">
        <group-as name="descriptions" in-json="ARRAY"/>
      </field>
    </model>
  </define-assembly>

</METASCHEMA>
