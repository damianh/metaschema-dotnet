<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    MSBuild targets for Metaschema.SourceGenerator.
    Converts MetaschemaFile items to AdditionalFiles for the source generator.
  -->
  
  <!-- Pass configuration to the source generator via global analyzer config -->
  <ItemGroup>
    <CompilerVisibleProperty Include="MetaschemaNamespace" />
    <CompilerVisibleProperty Include="MetaschemaVisibility" />
  </ItemGroup>
  
  <!-- Convert MetaschemaFile items to AdditionalFiles so the source generator can access them -->
  <Target Name="AddMetaschemaFilesToAdditionalFiles" BeforeTargets="GenerateMSBuildEditorConfigFileCore">
    <ItemGroup>
      <AdditionalFiles Include="@(MetaschemaFile)" />
    </ItemGroup>
  </Target>

</Project>
